# Copy this file to ".env" (same directory as docker-compose.yml) and fill in
# your public address. docker compose substitutes ${VAR} references from .env.
#
# NOTE: All BACKEND secrets (MONGO_URL, JWT_SECRET, Cloudinary, SMTP, ADMIN_*,
# etc.) live in Golden-Al-Sham-Backend/.env — NOT here.

# ── Public origin the app is served from (via nginx) ───────────────────
# Used as the frontend API base URL (baked into the bundle at build time)
# AND as the backend CORS origin / link base. Because the app and API share
# one origin with path-based routing, this is a single value.
#
#   Bare IP over HTTP:  http://13.251.243.201     (use your Elastic IP)
#   Domain over HTTPS:  https://goldenalsham.com  (after DNS + Certbot)
VITE_API_BASE_URL=https://goldenalsham.com
APP_ORIGIN=https://goldenalsham.com

# ── Auth cookie security ───────────────────────────────────────────────
# false → SameSite=Lax cookies that work over plain HTTP (bare-IP deploy).
# true  → SameSite=None; Secure cookies, REQUIRED when serving over HTTPS.
# Rule of thumb: HTTP → false, HTTPS → true. A mismatch breaks login.
COOKIE_SECURE=true
