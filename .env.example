# Copy this file to ".env" (same directory as docker-compose.yml) and fill in
# your public address. docker compose substitutes ${VAR} references from .env.
#
# NOTE: All BACKEND secrets (MONGO_URL, JWT_SECRET, Cloudinary, SMTP, ADMIN_*,
# etc.) live in Golden-Al-Sham-Backend/.env — NOT here.

# ── Public origin the app is served from (via nginx) ───────────────────
# Used as the frontend API base URL (baked into the bundle at build time)
# AND as the backend CORS origin. Because the app and API share one origin
# with path-based routing, this is a single value.
#
#   Bare IP:    http://13.48.123.45      (use your Elastic IP)
#   Domain:     https://your-domain.com  (after DNS + Certbot)
VITE_API_BASE_URL=http://YOUR_ELASTIC_IP
APP_ORIGIN=http://YOUR_ELASTIC_IP
